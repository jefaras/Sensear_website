{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/[lang]/layout,_N_T_/[lang]/test-forms/layout,_N_T_/[lang]/test-forms/page,_N_T_/en/test-forms"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/$d$lang/test-forms/__PAGE__",
    "/$d$lang/test-forms",
    "/$d$lang",
    "/_index",
    "/_head"
  ]
}